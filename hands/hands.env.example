# Dominion AI hands node — env template. Copy to hands/.env (Linux) or set as a scheduled-task
# environment (Windows). NEVER commit the filled-in file. Values are read at runtime, never inlined.

# The orchestrator base URL the node dials OUT to (Railway URL in production, or a laptop for tests).
HANDS_URL=https://<orchestrator-host>

# Shared bearer secret. MUST match the orchestrator's HANDS_TOKEN. No token -> the node refuses to
# start and the hub answers 503. Auth exists before the surface does (ledger L-017).
HANDS_TOKEN=<shared-secret>

# This node's name in the hub registry (default: the machine hostname, lowercased).
HANDS_NODE=mini-pc

# --- ACCESS (pick ONE style) ---
# Max access per Fred's spec: the whole machine minus the ironclad carve-outs.
#   Windows native: HANDS_MAX_ACCESS=1  (every fixed drive except D:\)
#   Linux/container: set HANDS_ROOTS=/host and bind-mount the host at /host (see docker-compose.yml)
HANDS_MAX_ACCESS=1
# Or scope it explicitly (unioned with max-access if both are set):
# HANDS_ROOTS=C:\,E:\

# Extra dirs to refuse writes under, on top of the built-ins (the live app dir + the node's own dir).
# HANDS_PROTECT=
